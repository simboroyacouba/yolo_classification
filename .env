# =============================================================================
# Configuration YOLO Détection - Toitures Cadastrales
# =============================================================================

# Fichier de classes
CLASSES_FILE=classes.yaml

# =============================================================================
# DATASET
# =============================================================================

# Dossier des images du dataset
DETECTION_DATASET_IMAGES_DIR=C:/Users/NEBRATA/Desktop/Memoire/Donnees/classification/dataset_all

# Fichier d'annotations COCO
DETECTION_DATASET_ANNOTATIONS_FILE=C:/Users/NEBRATA/Desktop/Memoire/Donnees/classification/dataset_all/instances_default.json

# Dossier des images pour inférence
DETECTION_INFERENCE_IMAGES_DIR=../test

# Dossier des images de test
DETECTION_TEST_IMAGES_DIR=../test

# =============================================================================
# MODÈLE YOLO
# =============================================================================

# Version YOLO: yolov8, yolov9, yolov10, yolov11, yolo11
# Pour YOLO25 quand disponible: yolo25
YOLO_VERSION=yolo26

# Taille du modèle: n (nano), s (small), m (medium), l (large), x (xlarge)
YOLO_SIZE=l

# =============================================================================
# ENTRAÎNEMENT
# =============================================================================

# NUM_EPOCHS=25
# NUM_EPOCHS=50
# BATCH_SIZE=8
# LEARNING_RATE=0.005
# MOMENTUM=0.937
# WEIGHT_DECAY=0.0005
# # IMAGE_SIZE=1280
# IMAGE_SIZE=640
# TRAIN_SPLIT=0.70
# VAL_SPLIT=0.20
# TEST_SPLIT=0.10

NUM_EPOCHS=30
BATCH_SIZE=8
LEARNING_RATE=0.0027129272809075836
MOMENTUM=0.8783633052497507
WEIGHT_DECAY=0.000010029989737103689
IMAGE_SIZE=1280
TRAIN_SPLIT=0.70
VAL_SPLIT=0.20
TEST_SPLIT=0.10

# =============================================================================
# ANNOTATIONS SPLITEES (generees par split_dataset.py)
# =============================================================================

# Mettre a jour ces chemins apres avoir lance : python split_dataset.py
NADIR_ANNOTATIONS_FILE=C:/Users/NEBRATA/Desktop/Memoire/Donnees/classification/dataset_all/instances_nadir.json
OBLIQUE_ANNOTATIONS_FILE=C:/Users/NEBRATA/Desktop/Memoire/Donnees/classification/dataset_all/instances_oblique.json

# =============================================================================
# SORTIE
# =============================================================================

OUTPUT_DIR=./output
EVALUATION_DIR=./evaluation
PREDICTIONS_DIR=./predictions
